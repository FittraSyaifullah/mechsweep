EXA_API_KEY=your_exa_api_key_here
EXA_BASE_URL=https://api.exa.ai
# auto (default, max quality) | fast | instant | deep-lite | deep | deep-reasoning
EXA_SEARCH_TYPE=auto
EXA_NUM_RESULTS=100
# Optional: research paper, news, company, people, personal site, financial report
# EXA_CATEGORY=research paper
# Optional comma-separated domain allowlist (e.g. edu,gov sites)
# EXA_INCLUDE_DOMAINS=arxiv.org,edu
# Set true for full page text on small batches
# EXA_FULL_CONTENTS=true
# Set true on Vercel Hobby (~10s limit) — disables summaries, smaller payloads
# EXA_LIGHTWEIGHT=true
# Results per batched /api/sweep call (max 100)
SWEEP_BATCH_SIZE=50
# Total unique results in one full sweep (batched calls, max = SWEEP_BATCH_SIZE × SWEEP_MAX_BATCHES)
SWEEP_SESSION_MAX=500
SWEEP_MAX_BATCHES=10
# Exa call timeout ms — use 9000 on Hobby, 55000 on Pro
SWEEP_SERVER_TIMEOUT_MS=55000
SEARCH_PROVIDER=exa
SWEEP_MISTRAL_FALLBACK=false

MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_BASE_URL=https://api.mistral.ai/v1
MISTRAL_ANALYZE_MODEL=mistral-small-latest
MISTRAL_SEARCH_MODEL=mistral-small-latest
MISTRAL_EMBEDDING_MODEL=mistral-embed

OPENROUTER_FALLBACK_ENABLED=false
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemini-2.5-flash-lite
OPENROUTER_ANALYZE_MODEL=google/gemini-2.5-flash-lite
OPENROUTER_SEARCH_MODEL=perplexity/sonar-pro
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase cloud library (optional — enables cross-device sync)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
