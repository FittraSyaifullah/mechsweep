EXA_API_KEY=your_exa_api_key_here
EXA_BASE_URL=https://api.exa.ai
# auto (quality, slower) | fast (recommended on Vercel Hobby) | instant
EXA_SEARCH_TYPE=fast
EXA_NUM_RESULTS=100
# Set true for summaries + full text (slower, may timeout on Hobby)
# EXA_FULL_CONTENTS=false
# Results per batched /api/sweep call (20 recommended for Vercel Hobby)
SWEEP_BATCH_SIZE=20
SWEEP_SERVER_TIMEOUT_MS=9000
# Total unique results collected in one full sweep (batched calls)
SWEEP_SESSION_MAX=200
SWEEP_MAX_BATCHES=10
# Optional override for per-request Exa result count (max 100)
# SWEEP_MAX_RESULTS=100
SEARCH_PROVIDER=exa
# Set true only to fall back to Mistral when Exa fails (Exa is primary by default)
SWEEP_MISTRAL_FALLBACK=false

MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_BASE_URL=https://api.mistral.ai/v1
MISTRAL_ANALYZE_MODEL=mistral-small-latest
MISTRAL_SEARCH_MODEL=mistral-small-latest
MISTRAL_EMBEDDING_MODEL=mistral-embed

# Optional: set to true only if you want OpenRouter as fallback when Mistral fails
OPENROUTER_FALLBACK_ENABLED=false

OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemini-2.5-flash-lite
OPENROUTER_ANALYZE_MODEL=google/gemini-2.5-flash-lite
OPENROUTER_SEARCH_MODEL=perplexity/sonar-pro
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small

NEXT_PUBLIC_APP_URL=http://localhost:3000
